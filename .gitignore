### AL ###
#Template for AL projects for Dynamics 365 Business Central
#launch.json folder
.vscode/
#Cache folder
.alcache/
#Symbols folder
.alpackages/
#Snapshots folder
.snapshots/
#Testing Output folder
.output/
#Extension App-file
*.app
#Rapid Application Development File
rad.json
#Translation Base-file
*.g.xlf
#License-file
*.flf
#Test results file
TestResults.xml

# Bỏ qua thư viện thư mục nặng nề
node_modules/

# Bỏ qua các file log lỗi của npm (nếu có)
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Bỏ qua các file rác do hệ điều hành tự sinh ra
.DS_Store
Thumbs.db

# Bỏ qua các file cấu hình cá nhân
*.env
*.local

# Bỏ qua package-lock.json và yarn.lock nếu bạn không muốn chia sẻ chúng
# package-lock.json
# yarn.lock
package-lock.json*
package.json*